# Parallel Merge Sort

from multiprocessing import Pool
import random
import time


# Merge function (combine two sorted lists)
def merge(left, right):
    result = []
    i = j = 0

    while i < len(left) and j < len(right):
        if left[i] < right[j]:
            result.append(left[i])
            i += 1
        else:
            result.append(right[j])
            j += 1

    # Add remaining elements
    result.extend(left[i:])
    result.extend(right[j:])
    return result


# Sequential Merge Sort (used inside each process)
def merge_sort(arr):
    if len(arr) <= 1:
        return arr

    mid = len(arr) // 2
    left = merge_sort(arr[:mid])
    right = merge_sort(arr[mid:])

    return merge(left, right)


# Parallel Merge Sort
def parallel_merge_sort(data):
    num_processes = 4  # divide into 4 parts

    # Split data into chunks
    chunk_size = len(data) // num_processes
    chunks = [data[i:i + chunk_size] for i in range(0, len(data), chunk_size)]

    # Create pool of processes
    with Pool(processes=num_processes) as pool:
        sorted_chunks = pool.map(merge_sort, chunks)

    # Merge all sorted chunks step by step
    while len(sorted_chunks) > 1:
        new_chunks = []

        for i in range(0, len(sorted_chunks), 2):
            if i + 1 < len(sorted_chunks):
                merged = merge(sorted_chunks[i], sorted_chunks[i + 1])
            else:
                merged = sorted_chunks[i]
            new_chunks.append(merged)

        sorted_chunks = new_chunks

    return sorted_chunks[0]


# Example usage
if __name__ == "__main__":
    N = 1000  # try 100000 or 1000000 later
    data = [random.randint(1, 1000000) for _ in range(N)]

    start = time.time()
    sorted_data = parallel_merge_sort(data)
    end = time.time()

    print("First 10 sorted values:", sorted_data[:10])
    print("Execution time:", end - start)
